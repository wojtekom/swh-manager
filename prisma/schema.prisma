generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                      String                    @id @default(cuid())
  email                   String                    @unique
  passwordHash            String
  name                    String
  phone                   String?
  avatar                  String?
  role                    Role                      @default(PARENT)
  active                  Boolean                   @default(true)
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  consentDataAt           DateTime?
  consentGoodPracticeAt   DateTime?
  consentHealthAt         DateTime?
  consentImageAt          DateTime?
  consentTravelAt         DateTime?
  announcementResponses   AnnouncementResponse[]
  announcements           Announcement[]
  camp_family_signups     camp_family_signups[]
  createdCamps            Camp[]                    @relation("campCreator")
  coach                   Coach?
  conversations           ConversationParticipant[]
  createdDrills           Drill[]                   @relation("drillCreator")
  issuedLoans             EquipmentLoan[]           @relation("loanIssuer")
  equipmentRequests       EquipmentRequest[]
  sentMessages            Message[]
  notificationPreferences NotificationPreference[]
  notifications           Notification[]
  orders                  Order[]
  parentPlayers           ParentPlayer[]
  playerUser              PlayerUser?
  pushSubscriptions       PushSubscription[]
  adminProposals          RequestProposal[]         @relation("adminProposals")
  tournaments             Tournament[]
  trainingPlans           TrainingPlan[]            @relation("planCreator")
  fitnessResults          FitnessTestResult[]       @relation("fitnessCreator")

  @@map("users")
}

model Player {
  id                       String                     @id @default(cuid())
  firstName                String
  lastName                 String
  dateOfBirth              DateTime
  pesel                    String?                    @unique
  category                 AgeCategory
  position                 PlayerPosition?
  jerseyNum                Int?
  photo                    String?
  status                   PlayerStatus               @default(ACTIVE)
  notes                    String?
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt
  swhCategory              SwhCategory                @default(MINI_HOKEJ)
  attendances              Attendance[]
  callups                  Callup[]
  campRegistrations        CampRegistration[]
  equipmentLoans           EquipmentLoan[]
  groupMembers             GroupMember[]
  orders                   Order[]
  parents                  ParentPlayer[]
  payments                 Payment[]
  player_fitness_tests     player_fitness_tests[]
  player_skill_assessments player_skill_assessments[]
  playerUser               PlayerUser?
  fitnessResults           FitnessTestResult[]

  @@map("players")
}

model ParentPlayer {
  id       String @id @default(cuid())
  parentId String
  playerId String
  parent   User   @relation(fields: [parentId], references: [id], onDelete: Cascade)
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([parentId, playerId])
  @@map("parent_players")
}

model PlayerUser {
  id       String @id @default(cuid())
  userId   String @unique
  playerId String @unique
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("player_users")
}

model Coach {
  id             String          @id @default(cuid())
  userId         String          @unique
  specialization String?
  licenseNum     String?
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainingGroups TrainingGroup[]

  @@map("coaches")
}

model TrainingGroup {
  id            String         @id @default(cuid())
  name          String
  category      AgeCategory
  coachId       String?
  createdAt     DateTime       @default(now())
  swhCategory   SwhCategory?
  announcements Announcement[]
  camps         Camp[]
  conversations Conversation[]
  members       GroupMember[]
  schedules     Schedule[]
  tournaments   Tournament[]
  coach         Coach?         @relation(fields: [coachId], references: [id])
  trainingPlans TrainingPlan[]

  @@map("training_groups")
}

model GroupMember {
  id       String        @id @default(cuid())
  groupId  String
  playerId String
  group    TrainingGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  player   Player        @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([groupId, playerId])
  @@map("group_members")
}

model Schedule {
  id               String            @id @default(cuid())
  groupId          String
  dayOfWeek        Int
  startTime        String
  endTime          String
  location         String
  recurring        Boolean           @default(true)
  active           Boolean           @default(true)
  createdAt        DateTime          @default(now())
  attendances      Attendance[]
  group            TrainingGroup     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  trainingSessions TrainingSession[]

  @@map("schedules")
}

model Attendance {
  id         String   @id @default(cuid())
  scheduleId String
  playerId   String
  date       DateTime
  present    Boolean  @default(false)
  note       String?
  player     Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, playerId, date])
  @@map("attendances")
}

model FeeDefinition {
  id        String       @id @default(cuid())
  name      String
  amount    Float
  frequency FeeFrequency
  groupId   String?
  active    Boolean      @default(true)
  createdAt DateTime     @default(now())
  payments  Payment[]

  @@map("fee_definitions")
}

model Payment {
  id         String        @id @default(cuid())
  playerId   String
  feeId      String
  amount     Float
  dueDate    DateTime
  paidDate   DateTime?
  paidAmount Float?
  status     PaymentStatus @default(PENDING)
  notes      String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  fee        FeeDefinition @relation(fields: [feeId], references: [id], onDelete: Cascade)
  player     Player        @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Recruitment {
  id                  String            @id @default(cuid())
  childFirstName      String
  childLastName       String
  childBirthDate      DateTime
  category            AgeCategory
  parentName          String
  parentEmail         String
  parentPhone         String
  experience          String?
  healthNotes         String?
  howFound            String?
  message             String?
  consentHealth       Boolean           @default(false)
  consentImage        Boolean           @default(false)
  consentTravel       Boolean           @default(false)
  consentGoodPractice Boolean           @default(false)
  consentData         Boolean           @default(false)
  status              RecruitmentStatus @default(NEW)
  adminNotes          String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@map("recruitments")
}

model Announcement {
  id        String                 @id @default(cuid())
  title     String
  content   String
  type      AnnouncementType       @default(INFO)
  authorId  String
  groupId   String?
  pinned    Boolean                @default(false)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  responses AnnouncementResponse[]
  author    User                   @relation(fields: [authorId], references: [id])
  group     TrainingGroup?         @relation(fields: [groupId], references: [id])

  @@map("announcements")
}

model AnnouncementResponse {
  id             String       @id @default(cuid())
  announcementId String
  userId         String
  response       String
  comment        String?
  createdAt      DateTime     @default(now())
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@map("announcement_responses")
}

model Conversation {
  id           String                    @id @default(cuid())
  name         String?
  groupId      String?
  isGroup      Boolean                   @default(false)
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  participants ConversationParticipant[]
  group        TrainingGroup?            @relation(fields: [groupId], references: [id])
  messages     Message[]

  @@map("conversations")
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  lastReadAt     DateTime     @default(now())
  joinedAt       DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@map("conversation_participants")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Tournament {
  id              String            @id @default(cuid())
  name            String
  location        String
  startDate       DateTime
  endDate         DateTime?
  category        AgeCategory
  description     String?
  status          TournamentStatus  @default(PLANNED)
  groupId         String?
  createdById     String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  transportFee    Float?
  meetingTime     DateTime?
  meetingLocation String?
  parentDeadline  DateTime?
  swhCategory     SwhCategory?
  callups         Callup[]
  matches         TournamentMatch[]
  createdBy       User              @relation(fields: [createdById], references: [id])
  group           TrainingGroup?    @relation(fields: [groupId], references: [id])

  @@map("tournaments")
}

model TournamentMatch {
  id            String     @id @default(cuid())
  tournamentId  String
  opponent      String
  isHome        Boolean    @default(true)
  ourScore      Int?
  opponentScore Int?
  matchDate     DateTime
  notes         String?
  createdAt     DateTime   @default(now())
  tournament    Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@map("tournament_matches")
}

model Callup {
  id              String          @id @default(cuid())
  tournamentId    String
  playerId        String
  status          CallupStatus    @default(CALLED)
  notes           String?
  respondedAt     DateTime?
  createdAt       DateTime        @default(now())
  transportChoice TransportChoice @default(UNDECIDED)
  notifiedAt      DateTime?
  player          Player          @relation(fields: [playerId], references: [id], onDelete: Cascade)
  tournament      Tournament      @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, playerId])
  @@map("callups")
}

model Camp {
  id                     String                @id @default(cuid())
  name                   String
  type                   CampType              @default(CAMP)
  location               String
  startDate              DateTime
  endDate                DateTime
  category               AgeCategory?
  description            String?
  cost                   Float                 @default(0)
  maxSpots               Int?
  status                 CampStatus            @default(PLANNED)
  groupId                String?
  createdById            String
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  priceAthleteBus        Float?
  priceAthleteOwn        Float?
  priceCompanionBus      Float?
  priceCompanionOwn      Float?
  signupOpen             Boolean               @default(false)
  signupDeadline         DateTime?
  maxCompanionsPerFamily Int                   @default(3)
  bankAccount            String?
  bankAccountHolder      String?
  paymentTitleTemplate   String?
  depositAmount          Float?
  depositDeadlineDays    Int                   @default(7)
  fullPaymentDeadline    DateTime?
  swhCategory            SwhCategory?
  camp_family_signups    camp_family_signups[]
  registrations          CampRegistration[]
  createdBy              User                  @relation("campCreator", fields: [createdById], references: [id])
  group                  TrainingGroup?        @relation(fields: [groupId], references: [id])

  @@map("camps")
}

model CampRegistration {
  id            String                 @id @default(cuid())
  campId        String
  playerId      String
  status        CampRegistrationStatus @default(REGISTERED)
  paidAmount    Float                  @default(0)
  parentNotes   String?
  adminNotes    String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  transportType TransportType          @default(BUS)
  totalCost     Float?
  camp          Camp                   @relation(fields: [campId], references: [id], onDelete: Cascade)
  player        Player                 @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([campId, playerId])
  @@map("camp_registrations")
}

model Equipment {
  id            String             @id @default(cuid())
  name          String
  category      EquipmentCategory
  brand         String?
  model         String?
  size          String?
  serialNum     String?
  condition     EquipmentCondition @default(NEW)
  quantity      Int                @default(1)
  available     Int                @default(1)
  location      String?
  purchaseDate  DateTime?
  purchasePrice Float?
  notes         String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  loans         EquipmentLoan[]

  @@map("equipment")
}

model EquipmentLoan {
  id          String              @id @default(cuid())
  equipmentId String
  playerId    String
  issuedById  String
  quantity    Int                 @default(1)
  loanDate    DateTime            @default(now())
  dueDate     DateTime?
  returnDate  DateTime?
  status      LoanStatus          @default(ACTIVE)
  condition   EquipmentCondition?
  notes       String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  equipment   Equipment           @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  issuedBy    User                @relation("loanIssuer", fields: [issuedById], references: [id])
  player      Player              @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@map("equipment_loans")
}

model Catalog {
  id          String        @id @default(cuid())
  name        String
  supplier    String
  description String?
  status      CatalogStatus @default(DRAFT)
  opensAt     DateTime?
  closesAt    DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  orders      Order[]
  products    Product[]

  @@index([status])
  @@map("catalogs")
}

model Product {
  id                String            @id @default(cuid())
  catalogId         String
  name              String
  description       String?
  brand             String
  equipmentCategory EquipmentCategory
  price             Float
  imageUrl          String?
  sizes             String[]
  sizeChartUrl      String?
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  ageGroup          String?
  level             String?
  productCode       String?
  orderItems        OrderItem[]
  catalog           Catalog           @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  proposals         RequestProposal[]

  @@index([catalogId])
  @@index([equipmentCategory])
  @@map("products")
}

model Order {
  id         String      @id @default(cuid())
  catalogId  String
  userId     String
  playerId   String
  status     OrderStatus @default(DRAFT)
  notes      String?
  totalPrice Float       @default(0)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  items      OrderItem[]
  catalog    Catalog     @relation(fields: [catalogId], references: [id])
  player     Player      @relation(fields: [playerId], references: [id])
  user       User        @relation(fields: [userId], references: [id])

  @@index([catalogId])
  @@index([userId])
  @@index([playerId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  size      String
  quantity  Int     @default(1)
  unitPrice Float
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

model EquipmentRequest {
  id                String            @id @default(cuid())
  userId            String
  name              String
  description       String?
  equipmentCategory EquipmentCategory
  quantity          Int               @default(1)
  priority          RequestPriority   @default(MEDIUM)
  status            RequestStatus     @default(PENDING)
  notes             String?
  adminNotes        String?
  reviewedAt        DateTime?
  reviewedBy        String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  maxBudget         Float?
  minBudget         Float?
  playerName        String?
  user              User              @relation(fields: [userId], references: [id])
  proposals         RequestProposal[]

  @@index([userId])
  @@index([status])
  @@map("equipment_requests")
}

model RequestProposal {
  id         String           @id @default(cuid())
  requestId  String
  productId  String
  adminId    String
  comment    String?
  isAccepted Boolean          @default(false)
  createdAt  DateTime         @default(now())
  admin      User             @relation("adminProposals", fields: [adminId], references: [id])
  product    Product          @relation(fields: [productId], references: [id])
  request    EquipmentRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@map("request_proposals")
}

model TrainingPlan {
  id            String            @id @default(cuid())
  name          String
  description   String?
  category      AgeCategory
  groupId       String?
  createdById   String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  parentPlanId  String?
  periodEnd     DateTime?
  periodStart   DateTime?
  planType      PlanType          @default(WEEKLY)
  season        String?
  summary       String?
  totalDuration Int               @default(0)
  totalSessions Int               @default(0)
  swhCategory   SwhCategory?
  createdBy     User              @relation("planCreator", fields: [createdById], references: [id])
  group         TrainingGroup?    @relation(fields: [groupId], references: [id])
  parentPlan    TrainingPlan?     @relation("PlanHierarchy", fields: [parentPlanId], references: [id])
  childPlans    TrainingPlan[]    @relation("PlanHierarchy")
  sessions      TrainingSession[]

  @@map("training_plans")
}

model TrainingSession {
  id                  String                @id @default(cuid())
  planId              String
  title               String
  date                DateTime?
  scheduleId          String?
  duration            Int                   @default(60)
  objectives          String?
  notes               String?
  order               Int                   @default(0)
  createdAt           DateTime              @default(now())
  topic               String?
  drills              SessionDrill[]
  session_skill_focus session_skill_focus[]
  plan                TrainingPlan          @relation(fields: [planId], references: [id], onDelete: Cascade)
  schedule            Schedule?             @relation(fields: [scheduleId], references: [id])

  @@map("training_sessions")
}

model Drill {
  id          String         @id @default(cuid())
  name        String
  category    DrillCategory
  description String?
  duration    Int?
  equipment   String?
  diagram     String?
  difficulty  Int            @default(1)
  ageGroups   String?
  createdById String
  createdAt   DateTime       @default(now())
  createdBy   User           @relation("drillCreator", fields: [createdById], references: [id])
  sessions    SessionDrill[]

  @@map("drills")
}

model SessionDrill {
  id        String          @id @default(cuid())
  sessionId String
  drillId   String
  order     Int             @default(0)
  duration  Int?
  notes     String?
  drill     Drill           @relation(fields: [drillId], references: [id], onDelete: Cascade)
  session   TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("session_drills")
}

model Notification {
  id        String              @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  link      String?
  channel   NotificationChannel @default(IN_APP)
  status    NotificationStatus  @default(PENDING)
  readAt    DateTime?
  sentAt    DateTime?
  errorMsg  String?
  metadata  String?
  createdAt DateTime            @default(now())
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, readAt])
  @@index([createdAt])
  @@map("notifications")
}

model NotificationPreference {
  id     String           @id @default(cuid())
  userId String
  type   NotificationType
  email  Boolean          @default(true)
  push   Boolean          @default(true)
  sms    Boolean          @default(false)
  inApp  Boolean          @default(true)
  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@map("notification_preferences")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

model camp_family_signups {
  id              String        @id
  campId          String
  parentId        String
  companionsCount Int           @default(0)
  companionNames  String?
  transportType   TransportType @default(BUS)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime
  camps           Camp          @relation(fields: [campId], references: [id], onDelete: Cascade)
  users           User          @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@unique([campId, parentId])
  @@index([campId])
}

model player_fitness_tests {
  id       String   @id
  playerId String
  testType String
  result   String
  period   String
  testDate DateTime @default(now())
  notes    String?
  players  Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([testType])
}

model player_skill_assessments {
  id                String            @id
  playerId          String
  skillId           String
  grade             String
  notes             String?
  assessedBy        String?
  assessedAt        DateTime          @default(now())
  players           Player            @relation(fields: [playerId], references: [id], onDelete: Cascade)
  skill_definitions skill_definitions @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([skillId])
}

model session_skill_focus {
  id                String            @id
  sessionId         String
  skillId           String
  intensity         String            @default("TRAIN")
  training_sessions TrainingSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  skill_definitions skill_definitions @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([sessionId, skillId])
  @@index([sessionId])
  @@index([skillId])
}

model skill_definitions {
  id                       String                     @id
  code                     String                     @unique
  name                     String
  description              String?
  category                 String
  sortOrder                Int                        @default(0)
  expectedU8               String?
  expectedU10              String?
  expectedU12              String?
  expectedU14              String?
  player_skill_assessments player_skill_assessments[]
  session_skill_focus      session_skill_focus[]

  @@index([category])
}

enum Role {
  ADMIN
  COACH
  PARENT
  PLAYER
}

enum PlayerStatus {
  ACTIVE
  INACTIVE
  INJURED
  SUSPENDED
}

enum PlayerPosition {
  GOALIE
  DEFENDER
  FORWARD
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIAL
  OVERDUE
}

enum FeeFrequency {
  MONTHLY
  QUARTERLY
  YEARLY
  ONE_TIME
}

enum AgeCategory {
  U8
  U10
  U12
  U14
  U16
  U18
  SENIOR
}

enum PlanType {
  YEARLY
  SEASONAL
  MONTHLY
  WEEKLY
}

enum NotificationType {
  TRAINING_REMINDER
  SCHEDULE_CHANGE
  SCHEDULE_CANCEL
  TOURNAMENT_UPDATE
  NEW_ANNOUNCEMENT
  NEW_MESSAGE
  CAMP_UPDATE
  PAYMENT_REMINDER
  CALLUP
}

enum NotificationChannel {
  IN_APP
  EMAIL
  PUSH
  SMS
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

enum RecruitmentStatus {
  NEW
  CONTACTED
  ACCEPTED
  REJECTED
}

enum AnnouncementType {
  INFO
  TRAINING
  MATCH
  RSVP
}

enum TournamentStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum CallupStatus {
  CALLED
  CONFIRMED
  DECLINED
  INJURED
}

enum CampType {
  CAMP
  TRIP
  WORKSHOP
}

enum CampStatus {
  PLANNED
  OPEN
  CLOSED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum CampRegistrationStatus {
  REGISTERED
  CONFIRMED
  WAITLIST
  CANCELLED
}

enum EquipmentCategory {
  HELMET
  SKATES
  STICK
  GLOVES
  PADS
  JERSEY
  PANTS
  BAG
  GOALIE_GEAR
  OTHER
