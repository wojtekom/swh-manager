generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==================== ENUMS ====================

enum Role {
  ADMIN
  COACH
  PARENT
  PLAYER
}

enum PlayerStatus {
  ACTIVE
  INACTIVE
  INJURED
  SUSPENDED
}

enum PlayerPosition {
  GOALIE
  DEFENDER
  FORWARD
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIAL
  OVERDUE
}

enum FeeFrequency {
  MONTHLY
  QUARTERLY
  YEARLY
  ONE_TIME
}

enum AgeCategory {
  U8
  U10
  U12
  U14
  U16
  U18
  SENIOR
}

enum PlanType {
  YEARLY    // plan roczny
  SEASONAL  // plan sezonowy (rolkowy / lodowy)
  MONTHLY   // plan miesięczny
  WEEKLY    // plan tygodniowy
}

enum NotificationType {
  TRAINING_REMINDER
  SCHEDULE_CHANGE
  SCHEDULE_CANCEL
  TOURNAMENT_UPDATE
  NEW_ANNOUNCEMENT
  NEW_MESSAGE
  CAMP_UPDATE
  PAYMENT_REMINDER
  CALLUP
}

enum NotificationChannel {
  IN_APP
  EMAIL
  PUSH
  SMS
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

// ==================== AUTH & USERS ====================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String
  phone         String?
  avatar        String?
  role          Role      @default(PARENT)
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  coach                  Coach?
  parentPlayers          ParentPlayer[]
  playerUser             PlayerUser?
  announcements          Announcement[]
  announcementResponses  AnnouncementResponse[]
  conversations          ConversationParticipant[]
  sentMessages           Message[]
  tournaments            Tournament[]
  createdCamps           Camp[]       @relation("campCreator")
  issuedLoans            EquipmentLoan[] @relation("loanIssuer")
  orders                 Order[]
  equipmentRequests      EquipmentRequest[]
  adminProposals         RequestProposal[] @relation("adminProposals")
  trainingPlans          TrainingPlan[]  @relation("planCreator")
  createdDrills          Drill[]         @relation("drillCreator")
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
  pushSubscriptions       PushSubscription[]

  // Zgody rodzica
  consentImageAt          DateTime?  // zgoda na wizerunek
  consentTravelAt         DateTime?  // zgoda na wyjazdy/turnieje
  consentHealthAt         DateTime?  // oświadczenie zdrowotne
  consentGoodPracticeAt   DateTime?  // dobre praktyki
  consentDataAt           DateTime?  // RODO

  @@map("users")
}

model Player {
  id          String         @id @default(cuid())
  firstName   String
  lastName    String
  dateOfBirth DateTime
  pesel       String?        @unique
  category    AgeCategory
  position    PlayerPosition?
  jerseyNum   Int?
  photo       String?
  status      PlayerStatus   @default(ACTIVE)
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  // Relations
  parents      ParentPlayer[]
  playerUser   PlayerUser?
  groupMembers GroupMember[]
  attendances  Attendance[]
  payments     Payment[]
  callups           Callup[]
  campRegistrations CampRegistration[]
  equipmentLoans    EquipmentLoan[]
  orders            Order[]

  @@map("players")
}

// Rodzic <-> Zawodnik (wiele do wielu)
model ParentPlayer {
  id       String @id @default(cuid())
  parentId String
  playerId String

  parent User   @relation(fields: [parentId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([parentId, playerId])
  @@map("parent_players")
}

// Zawodnik 16+ z własnym kontem
model PlayerUser {
  id       String @id @default(cuid())
  userId   String @unique
  playerId String @unique

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@map("player_users")
}

model Coach {
  id             String  @id @default(cuid())
  userId         String  @unique
  specialization String?
  licenseNum     String?

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainingGroups TrainingGroup[]

  @@map("coaches")
}

// ==================== GRUPY TRENINGOWE ====================

model TrainingGroup {
  id        String      @id @default(cuid())
  name      String
  category  AgeCategory
  coachId   String?
  createdAt DateTime    @default(now())

  coach         Coach?         @relation(fields: [coachId], references: [id], onDelete: SetNull)
  members       GroupMember[]
  schedules     Schedule[]
  announcements  Announcement[]
  conversations  Conversation[]
  tournaments    Tournament[]
  camps          Camp[]
  trainingPlans  TrainingPlan[]

  @@map("training_groups")
}

model GroupMember {
  id       String @id @default(cuid())
  groupId  String
  playerId String

  group  TrainingGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  player Player        @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([groupId, playerId])
  @@map("group_members")
}

// ==================== HARMONOGRAM I OBECNOŚCI ====================

model Schedule {
  id        String   @id @default(cuid())
  groupId   String
  dayOfWeek Int      // 0=Niedz, 1=Pon, ..., 6=Sob
  startTime String   // "17:00"
  endTime   String   // "18:30"
  location  String
  recurring Boolean  @default(true)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  group       TrainingGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  attendances Attendance[]
  trainingSessions TrainingSession[]

  @@map("schedules")
}

model Attendance {
  id         String   @id @default(cuid())
  scheduleId String
  playerId   String
  date       DateTime
  present    Boolean  @default(false)
  note       String?

  schedule Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  player   Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, playerId, date])
  @@map("attendances")
}

// ==================== SKŁADKI I PŁATNOŚCI ====================

model FeeDefinition {
  id        String       @id @default(cuid())
  name      String
  amount    Float
  frequency FeeFrequency
  groupId   String?      // null = dotyczy wszystkich
  active    Boolean      @default(true)
  createdAt DateTime     @default(now())

  payments Payment[]

  @@map("fee_definitions")
}

model Payment {
  id        String        @id @default(cuid())
  playerId  String
  feeId     String
  amount    Float
  dueDate   DateTime
  paidDate  DateTime?
  paidAmount Float?
  status    PaymentStatus @default(PENDING)
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  player Player        @relation(fields: [playerId], references: [id], onDelete: Cascade)
  fee    FeeDefinition @relation(fields: [feeId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// ==================== NABÓR / REKRUTACJA ====================

enum RecruitmentStatus {
  NEW
  CONTACTED
  ACCEPTED
  REJECTED
}

model Recruitment {
  id              String            @id @default(cuid())
  // Dane dziecka
  childFirstName  String
  childLastName   String
  childBirthDate  DateTime
  category        AgeCategory
  // Dane rodzica/opiekuna
  parentName      String
  parentEmail     String
  parentPhone     String
  // Dodatkowe
  experience      String?           // doświadczenie hokejowe
  healthNotes     String?           // uwagi zdrowotne
  howFound        String?           // skąd dowiedzieli się o klubie
  message         String?           // dodatkowa wiadomość
  // Zgody
  consentHealth       Boolean @default(false) // oświadczenie o stanie zdrowia
  consentImage        Boolean @default(false) // zgoda na wykorzystanie wizerunku
  consentTravel       Boolean @default(false) // zgoda na udział w meczach/turniejach wyjazdowych
  consentGoodPractice Boolean @default(false) // zgoda na dobre praktyki / regulamin
  consentData         Boolean @default(false) // zgoda na przetwarzanie danych osobowych
  // Status
  status          RecruitmentStatus @default(NEW)
  adminNotes      String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@map("recruitments")
}

// ==================== KOMUNIKACJA ====================

enum AnnouncementType {
  INFO          // ogłoszenie informacyjne
  TRAINING      // dotyczy treningu
  MATCH         // dotyczy meczu/turnieju
  RSVP          // wymaga potwierdzenia
}

model Announcement {
  id          String           @id @default(cuid())
  title       String
  content     String
  type        AnnouncementType @default(INFO)
  authorId    String
  groupId     String?          // null = do wszystkich
  pinned      Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  author      User             @relation(fields: [authorId], references: [id])
  group       TrainingGroup?   @relation(fields: [groupId], references: [id], onDelete: SetNull)
  responses   AnnouncementResponse[]

  @@map("announcements")
}

model AnnouncementResponse {
  id              String       @id @default(cuid())
  announcementId  String
  userId          String
  response        String       // "yes" | "no" | "maybe"
  comment         String?
  createdAt       DateTime     @default(now())

  announcement    Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@map("announcement_responses")
}

// ==================== KOMUNIKATOR ====================

model Conversation {
  id        String   @id @default(cuid())
  name      String?  // null dla 1:1, nazwa dla grupowych
  groupId   String?  // powiązana grupa treningowa (opcjonalnie)
  isGroup   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group        TrainingGroup?            @relation(fields: [groupId], references: [id], onDelete: SetNull)
  participants ConversationParticipant[]
  messages     Message[]

  @@map("conversations")
}

model ConversationParticipant {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  lastReadAt     DateTime @default(now())
  joinedAt       DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@map("conversation_participants")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@map("messages")
}

// ==================== TURNIEJE I POWOŁANIA ====================

enum TournamentStatus {
  PLANNED       // zaplanowany
  IN_PROGRESS   // w trakcie
  COMPLETED     // zakończony
  CANCELLED     // odwołany
}

enum CallupStatus {
  CALLED        // powołany
  CONFIRMED     // potwierdzony
  DECLINED      // odmówił
  INJURED       // kontuzjowany
}

model Tournament {
  id          String           @id @default(cuid())
  name        String
  location    String
  startDate   DateTime
  endDate     DateTime?
  category    AgeCategory
  description String?
  status      TournamentStatus @default(PLANNED)
  groupId     String?          // powiązana grupa treningowa
  createdById String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  group     TrainingGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  createdBy User           @relation(fields: [createdById], references: [id])
  matches   TournamentMatch[]
  callups   Callup[]

  @@map("tournaments")
}

model TournamentMatch {
  id           String    @id @default(cuid())
  tournamentId String
  opponent     String
  isHome       Boolean   @default(true)
  ourScore     Int?
  opponentScore Int?
  matchDate    DateTime
  notes        String?
  createdAt    DateTime  @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@map("tournament_matches")
}

model Callup {
  id           String       @id @default(cuid())
  tournamentId String
  playerId     String
  status       CallupStatus @default(CALLED)
  notes        String?
  respondedAt  DateTime?
  createdAt    DateTime     @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player     Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, playerId])
  @@map("callups")
}

// ==================== OBOZY I WYJAZDY ====================

enum CampType {
  CAMP          // obóz sportowy
  TRIP          // wyjazd na turniej/mecz
  WORKSHOP      // warsztaty / szkolenie
}

enum CampStatus {
  PLANNED
  OPEN          // zapisy otwarte
  CLOSED        // zapisy zamknięte
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum CampRegistrationStatus {
  REGISTERED    // zapisany
  CONFIRMED     // potwierdzony (opłacony)
  WAITLIST      // lista rezerwowa
  CANCELLED     // anulowany
}

model Camp {
  id            String     @id @default(cuid())
  name          String
  type          CampType   @default(CAMP)
  location      String
  startDate     DateTime
  endDate       DateTime
  category      AgeCategory?
  description   String?
  cost          Float      @default(0)
  maxSpots      Int?
  status        CampStatus @default(PLANNED)
  groupId       String?
  createdById   String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  group         TrainingGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  createdBy     User           @relation("campCreator", fields: [createdById], references: [id])
  registrations CampRegistration[]

  @@map("camps")
}

model CampRegistration {
  id          String                   @id @default(cuid())
  campId      String
  playerId    String
  status      CampRegistrationStatus   @default(REGISTERED)
  paidAmount  Float                    @default(0)
  parentNotes String?
  adminNotes  String?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  camp   Camp   @relation(fields: [campId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([campId, playerId])
  @@map("camp_registrations")
}

// ==================== SPRZĘT, MAGAZYN, WYPOŻYCZALNIA ====================

enum EquipmentCategory {
  HELMET        // kask
  SKATES        // łyżwy
  ROLLER_SKATES // łyżworolki
  STICK         // kij
  GLOVES        // rękawice
  PADS          // ochraniacze (naramienniki, łokcie, golenie)
  JERSEY        // koszulka
  PANTS         // spodnie hokejowe
  BAG           // torba
  GOALIE_GEAR   // sprzęt bramkarski
  NECK_GUARD    // ochraniacz szyi
  MOUTHGUARD    // ochraniacz na zęby
  TRAINING_AID  // pomoce treningowe
  ACCESSORY     // akcesoria (sznurówki, paski, bidony)
  OTHER         // inne
}

enum EquipmentCondition {
  NEW
  GOOD
  FAIR
  POOR
  DAMAGED
  RETIRED       // wycofany
}

enum LoanStatus {
  ACTIVE        // wypożyczony
  RETURNED      // zwrócony
  OVERDUE       // po terminie
  LOST          // zgubiony
}

model Equipment {
  id          String             @id @default(cuid())
  name        String
  category    EquipmentCategory
  brand       String?
  model       String?
  size        String?
  serialNum   String?
  condition   EquipmentCondition @default(NEW)
  quantity    Int                @default(1)
  available   Int                @default(1)
  location    String?            // lokalizacja w magazynie
  purchaseDate DateTime?
  purchasePrice Float?
  notes       String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  loans EquipmentLoan[]

  @@map("equipment")
}

model EquipmentLoan {
  id           String     @id @default(cuid())
  equipmentId  String
  playerId     String
  issuedById   String     // kto wydał
  quantity     Int        @default(1)
  loanDate     DateTime   @default(now())
  dueDate      DateTime?
  returnDate   DateTime?
  status       LoanStatus @default(ACTIVE)
  condition    EquipmentCondition? // stan przy zwrocie
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  equipment Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  player    Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  issuedBy  User      @relation("loanIssuer", fields: [issuedById], references: [id])

  @@map("equipment_loans")
}

// ==================== ZAMÓWIENIA SPRZĘTU (przez stowarzyszenie) ====================

enum CatalogStatus {
  DRAFT
  OPEN
  CLOSED
  COMPLETED
}

enum OrderStatus {
  DRAFT
  SUBMITTED
  CONFIRMED
  ORDERED
  DELIVERED
  CANCELLED
}

model Catalog {
  id          String        @id @default(cuid())
  name        String
  supplier    String
  description String?
  status      CatalogStatus @default(DRAFT)
  opensAt     DateTime?
  closesAt    DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  products Product[]
  orders   Order[]

  @@index([status])
  @@map("catalogs")
}

model Product {
  id                String            @id @default(cuid())
  catalogId         String
  name              String
  description       String?
  brand             String
  equipmentCategory EquipmentCategory
  productCode       String?           // kod producenta (np. SKXR90, RHFT850)
  ageGroup          String?           // YT (Youth), JR (Junior), INT (Intermediate), SR (Senior)
  level             String?           // Elite, Premium, Mid, Entry, Budget
  price             Float
  imageUrl          String?
  sizes             String[]
  sizeChartUrl      String?
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  catalog    Catalog           @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  proposals  RequestProposal[]

  @@index([catalogId])
  @@index([equipmentCategory])
  @@map("products")
}

model Order {
  id         String      @id @default(cuid())
  catalogId  String
  userId     String
  playerId   String
  status     OrderStatus @default(DRAFT)
  notes      String?
  totalPrice Float       @default(0)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  catalog Catalog   @relation(fields: [catalogId], references: [id])
  user    User      @relation(fields: [userId], references: [id])
  player  Player    @relation(fields: [playerId], references: [id])
  items   OrderItem[]

  @@index([catalogId])
  @@index([userId])
  @@index([playerId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  size      String
  quantity  Int     @default(1)
  unitPrice Float

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

// ==================== ZAPOTRZEBOWANIE SPRZĘTU (TRENER + RODZIC) ====================

enum RequestPriority {
  LOW
  MEDIUM
  HIGH
}

enum RequestStatus {
  PENDING
  PROPOSED     // admin zaproponował produkt z katalogu
  ACCEPTED     // rodzic zaakceptował propozycję
  APPROVED
  REJECTED
  FULFILLED
}

model EquipmentRequest {
  id                String            @id @default(cuid())
  userId            String
  playerName        String?           // imię dziecka (dla rodzica)
  name              String
  description       String?
  equipmentCategory EquipmentCategory
  quantity          Int               @default(1)
  priority          RequestPriority   @default(MEDIUM)
  status            RequestStatus     @default(PENDING)
  minBudget         Float?            // min budżet rodzica (EUR)
  maxBudget         Float?            // max budżet rodzica (EUR)
  notes             String?
  adminNotes        String?
  reviewedAt        DateTime?
  reviewedBy        String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  user      User                @relation(fields: [userId], references: [id])
  proposals RequestProposal[]

  @@index([userId])
  @@index([status])
  @@map("equipment_requests")
}

model RequestProposal {
  id          String   @id @default(cuid())
  requestId   String
  productId   String
  adminId     String
  comment     String?   // komentarz admina dlaczego ten produkt
  isAccepted  Boolean   @default(false)
  createdAt   DateTime  @default(now())

  request EquipmentRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  product Product          @relation(fields: [productId], references: [id])
  admin   User             @relation("adminProposals", fields: [adminId], references: [id])

  @@index([requestId])
  @@map("request_proposals")
}

// ==================== PROGRAM SZKOLENIOWY ====================

enum DrillCategory {
  SKATING         // jazda na łyżwach
  SHOOTING        // strzały
  PASSING         // podania
  STICKHANDLING   // prowadzenie krążka
  TACTICS         // taktyka
  CONDITIONING    // kondycja / wytrzymałość
  GOALIE          // ćwiczenia bramkarskie
  WARMUP          // rozgrzewka
  COOLDOWN        // schładzanie
  GAME            // gra / scrimmage
}

model TrainingPlan {
  id            String      @id @default(cuid())
  name          String
  description   String?
  category      AgeCategory
  planType      PlanType    @default(WEEKLY)
  parentPlanId  String?
  season        String?     // np. "2026/2027", "roller-2026", "ice-2026"
  periodStart   DateTime?   // początek okresu
  periodEnd     DateTime?   // koniec okresu
  summary       String?     // auto-generowane podsumowanie z planów podrzędnych
  totalSessions Int         @default(0) // łączna liczba sesji (w tym z podplanów)
  totalDuration Int         @default(0) // łączny czas (min) z podplanów
  groupId       String?
  createdById   String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  parentPlan TrainingPlan?   @relation("PlanHierarchy", fields: [parentPlanId], references: [id], onDelete: SetNull)
  childPlans TrainingPlan[]  @relation("PlanHierarchy")
  group      TrainingGroup?  @relation(fields: [groupId], references: [id], onDelete: SetNull)
  createdBy  User            @relation("planCreator", fields: [createdById], references: [id])
  sessions   TrainingSession[]

  @@map("training_plans")
}

model TrainingSession {
  id          String   @id @default(cuid())
  planId      String
  title       String
  date        DateTime?
  scheduleId  String?      // powiązanie z harmonogramem
  duration    Int          @default(60) // minuty
  objectives  String?      // cele sesji
  notes       String?
  order       Int          @default(0)
  createdAt   DateTime     @default(now())

  plan     TrainingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  schedule Schedule?    @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  drills   SessionDrill[]

  @@map("training_sessions")
}

model Drill {
  id          String        @id @default(cuid())
  name        String
  category    DrillCategory
  description String?
  duration    Int?          // minuty
  equipment   String?       // wymagany sprzęt
  diagram     String?       // URL do schematu
  difficulty  Int           @default(1) // 1-5
  ageGroups   String?       // "U8,U10,U12" — kompatybilne grupy
  createdById String
  createdAt   DateTime      @default(now())

  createdBy User           @relation("drillCreator", fields: [createdById], references: [id])
  sessions  SessionDrill[]

  @@map("drills")
}

model SessionDrill {
  id        String @id @default(cuid())
  sessionId String
  drillId   String
  order     Int    @default(0)
  duration  Int?   // nadpisanie czasu ćwiczenia
  notes     String?

  session TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  drill   Drill           @relation(fields: [drillId], references: [id], onDelete: Cascade)

  @@map("session_drills")
}

// ==================== POWIADOMIENIA ====================

model Notification {
  id        String              @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  link      String?
  channel   NotificationChannel @default(IN_APP)
  status    NotificationStatus  @default(PENDING)
  readAt    DateTime?
  sentAt    DateTime?
  errorMsg  String?
  metadata  String?
  createdAt DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, readAt])
  @@index([createdAt])
  @@map("notifications")
}

model NotificationPreference {
  id     String           @id @default(cuid())
  userId String
  type   NotificationType
  email  Boolean          @default(true)
  push   Boolean          @default(true)
  sms    Boolean          @default(false)
  inApp  Boolean          @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@map("notification_preferences")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}
